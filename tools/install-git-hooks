#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Install this repository's committed Git hooks.

Usage:
  tools/install-git-hooks [--help]

Environment:
  PATH  Must include git.

The script sets this clone's local core.hooksPath to .githooks.
USAGE
}

if [[ "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -ne 0 ]]; then
  usage >&2
  exit 2
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

git rev-parse --git-dir >/dev/null
git config core.hooksPath .githooks

echo "Installed Git hooks from .githooks."
